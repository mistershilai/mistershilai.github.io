---
// Drop-in wrapper that fades children in on scroll.
// Usage: <ScrollReveal delay={100}> ... </ScrollReveal>
interface Props {
  delay?: number;
  class?: string;
}
const { delay = 0, class: cls = '' } = Astro.props;
---

<div class:list={["reveal", cls]} style={`transition-delay:${delay}ms`}>
  <slot />
</div>

<script>
  function wireReveals() {
    const els = document.querySelectorAll<HTMLElement>('.reveal:not(.is-visible)');
    if (!('IntersectionObserver' in window)) {
      els.forEach(el => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    els.forEach(el => io.observe(el));
  }
  wireReveals();
  document.addEventListener('astro:page-load', wireReveals);
</script>
