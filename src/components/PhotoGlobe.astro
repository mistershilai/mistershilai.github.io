---
import { places } from '@/data/photos';
---

<div id="pg-wrap" class="relative w-full max-w-xl aspect-square mx-auto">
  <canvas id="pg-canvas" class="w-full h-full rounded-full cursor-grab" data-places={JSON.stringify(places)}></canvas>
  <div class="pointer-events-none absolute inset-0 rounded-full shadow-[inset_0_0_80px_rgba(0,119,190,0.2)]"></div>
  <div id="pg-vidpop" class="pg-vidpop" aria-hidden="true">
    <button id="pg-vidpop-close" class="pg-popup-close" aria-label="Close preview">×</button>
    <video id="pg-vidpop-video" class="pg-vidpop-video" muted loop playsinline preload="metadata"></video>
    <div class="pg-vidpop-meta">
      <div id="pg-vidpop-title" class="pg-vidpop-title"></div>
      <div id="pg-vidpop-desc" class="pg-vidpop-desc"></div>
    </div>
  </div>
  <!-- Cluster inset: zoomed-in 3D view of the hovered region so users can pick overlapping pins -->
  <div id="pg-cluster" class="pg-cluster" aria-hidden="true">
    <button id="pg-cluster-close" class="pg-popup-close" aria-label="Close zoomed view">×</button>
    <div class="pg-cluster-title">Zoomed in</div>
    <canvas id="pg-cluster-canvas" class="pg-cluster-canvas" width="280" height="280"></canvas>
    <div id="pg-cluster-label" class="pg-cluster-label"></div>
  </div>
</div>
<p id="pg-hint" class="mt-5 text-center text-xs font-sans opacity-50 transition-opacity">
  click a pin to zoom · drag to rotate
</p>

<div id="pg-panel" class="pg-panel" aria-hidden="true">
  <button id="pg-close" class="pg-close" aria-label="Close">×</button>
  <div class="flex items-baseline justify-between gap-4 mb-3">
    <h2 id="pg-title" class="font-serif font-bold text-2xl md:text-3xl"></h2>
    <div id="pg-year" class="font-sans text-sm opacity-60"></div>
  </div>
  <p id="pg-blurb" class="font-serif opacity-80 mb-5"></p>
  <div id="pg-grid" class="grid grid-cols-2 md:grid-cols-3 gap-3"></div>
</div>

<style>
  .pg-panel {
    max-width: 64rem;
    margin: 2.5rem auto 0;
    padding: 1.75rem;
    border-radius: 14px;
    background: rgba(255,255,255,0.8);
    backdrop-filter: blur(8px);
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    display: none;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
    position: relative;
  }
  :global(.dark) .pg-panel {
    background: rgba(23,27,34,0.8);
    box-shadow: 0 10px 40px rgba(0,0,0,0.4);
  }
  .pg-panel.visible {
    display: block;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .pg-close {
    position: absolute;
    top: 0.75rem;
    right: 0.9rem;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    line-height: 1;
    background: transparent;
    border: 1px solid rgba(0,0,0,0.12);
    color: inherit;
    cursor: pointer;
    transition: background 0.2s;
  }
  :global(.dark) .pg-close { border-color: rgba(255,255,255,0.15); }
  .pg-close:hover { background: rgba(0,0,0,0.05); }
  :global(.dark) .pg-close:hover { background: rgba(255,255,255,0.1); }
  .pg-photo {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    aspect-ratio: 4 / 3;
    background: rgba(0,0,0,0.05);
  }
  :global(.dark) .pg-photo { background: rgba(255,255,255,0.05); }
  .pg-photo img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.5s ease;
  }
  .pg-photo:hover img { transform: scale(1.05); }
  #pg-canvas.grabbing { cursor: grabbing; }

  /* Video preview popup: appears next to orange (video) pins on hover/tap */
  .pg-vidpop {
    position: fixed;
    z-index: 50;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 0.6rem;
    width: 320px;
    max-width: calc(100vw - 2rem);
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 12px;
    box-shadow: 0 12px 36px rgba(0,0,0,0.18);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }
  :global(.dark) .pg-vidpop {
    background: rgba(23,27,34,0.92);
    border-color: rgba(255,255,255,0.08);
    box-shadow: 0 12px 36px rgba(0,0,0,0.5);
  }
  .pg-vidpop.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .pg-vidpop-video {
    width: 120px;
    height: 90px;
    object-fit: cover;
    border-radius: 8px;
    background: rgba(0,0,0,0.1);
    flex-shrink: 0;
  }
  .pg-vidpop-meta {
    flex: 1;
    min-width: 0;
  }
  .pg-vidpop-title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.2;
    margin-bottom: 0.25rem;
  }
  .pg-vidpop-desc {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    line-height: 1.35;
    opacity: 0.75;
  }
  /* Video in click panel sits above the photo grid */
  .pg-panel-video {
    width: 100%;
    max-height: 360px;
    border-radius: 10px;
    background: rgba(0,0,0,0.05);
    margin-bottom: 1rem;
  }
  :global(.dark) .pg-panel-video { background: rgba(255,255,255,0.05); }

  /* Cluster inset: zoomed-in mini-globe view of the hovered region */
  .pg-cluster {
    position: fixed;
    z-index: 51;
    width: 280px;
    padding: 0.5rem 0.6rem 0.6rem;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 12px;
    box-shadow: 0 12px 36px rgba(0,0,0,0.18);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.15s ease, transform 0.15s ease;
    pointer-events: none;
  }
  :global(.dark) .pg-cluster {
    background: rgba(23,27,34,0.92);
    border-color: rgba(255,255,255,0.08);
    box-shadow: 0 12px 36px rgba(0,0,0,0.5);
  }
  .pg-cluster.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .pg-cluster-title {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.55;
    margin-bottom: 0.4rem;
  }
  .pg-cluster-canvas {
    display: block;
    width: 268px;
    height: 268px;
    border-radius: 8px;
    cursor: pointer;
    background: rgba(0,0,0,0.04);
  }
  :global(.dark) .pg-cluster-canvas { background: rgba(255,255,255,0.04); }
  .pg-cluster-label {
    font-family: var(--font-serif);
    font-size: 0.8rem;
    line-height: 1.25;
    margin-top: 0.45rem;
    min-height: 1.1em;
    opacity: 0.85;
    text-align: center;
  }

  /* Small close button shared by both popups (helps touch users) */
  .pg-popup-close {
    position: absolute;
    top: 4px;
    right: 6px;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    line-height: 1;
    background: transparent;
    border: 1px solid rgba(0,0,0,0.12);
    color: inherit;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.15s, background 0.15s;
  }
  .pg-popup-close:hover { opacity: 1; background: rgba(0,0,0,0.05); }
  :global(.dark) .pg-popup-close { border-color: rgba(255,255,255,0.18); }
  :global(.dark) .pg-popup-close:hover { background: rgba(255,255,255,0.1); }

  /* Narrow viewport: shrink popups so they don't crowd a small wrap */
  @media (max-width: 480px) {
    .pg-vidpop { width: 260px; }
    .pg-vidpop-video { width: 96px; height: 72px; }
    .pg-cluster { width: 240px; }
    .pg-cluster-canvas { width: 228px; height: 228px; }
  }
</style>

<script>
  import * as THREE from 'three';
  import { feature, mesh } from 'topojson-client';

  const VISITED_IDS = new Set([
    '076', '710', '072', '516', '716', '894', '634', '156', '356', '352',
    '124', '840', '044', '792', '392', '426', '222',
  ]);

  type Video = { file: string; description?: string };
  type Place = {
    slug: string;
    name: string;
    lat: number;
    lon: number;
    year?: string;
    blurb?: string;
    photos: { file: string; caption?: string }[];
    video?: Video;
  };

  function latLonToVec3(lat: number, lon: number, r: number) {
    const phi = (90 - lat) * (Math.PI / 180);
    const theta = (lon + 180) * (Math.PI / 180);
    return new THREE.Vector3(
      -r * Math.sin(phi) * Math.cos(theta),
      r * Math.cos(phi),
      r * Math.sin(phi) * Math.sin(theta)
    );
  }

  function ringToLine(ring: number[][], r: number, material: THREE.LineBasicMaterial) {
    const pts = ring.map(([lon, lat]) => latLonToVec3(lat, lon, r));
    const geo = new THREE.BufferGeometry().setFromPoints(pts);
    return new THREE.Line(geo, material);
  }
  function ringFillMesh(ring: number[][], holes: number[][][], r: number, material: THREE.Material) {
    // Triangulate in lon/lat space, then project each vertex onto the sphere.
    // Works fine for the small lake polygons in the 110m dataset.
    const contour2 = ring.map(([lon, lat]) => new THREE.Vector2(lon, lat));
    const holes2 = holes.map(h => h.map(([lon, lat]) => new THREE.Vector2(lon, lat)));
    const tris = (THREE as any).ShapeUtils.triangulateShape(contour2, holes2);
    const positions: number[] = [];
    const allPts = [ring, ...holes];
    for (const arr of allPts) {
      for (const [lon, lat] of arr) {
        const v = latLonToVec3(lat, lon, r);
        positions.push(v.x, v.y, v.z);
      }
    }
    const indices: number[] = [];
    for (const t of tris) indices.push(t[0], t[1], t[2]);
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
    geo.setIndex(indices);
    return new THREE.Mesh(geo, material);
  }
  function meshToLineSegments(ls: any, r: number, material: THREE.LineBasicMaterial) {
    const positions: number[] = [];
    for (const line of ls.coordinates) {
      for (let i = 0; i < line.length - 1; i++) {
        const [lon1, lat1] = line[i];
        const [lon2, lat2] = line[i + 1];
        const p1 = latLonToVec3(lat1, lon1, r);
        const p2 = latLonToVec3(lat2, lon2, r);
        positions.push(p1.x, p1.y, p1.z, p2.x, p2.y, p2.z);
      }
    }
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
    return new THREE.LineSegments(geo, material);
  }

  async function init() {
    const canvas = document.getElementById('pg-canvas') as HTMLCanvasElement | null;
    const panel = document.getElementById('pg-panel');
    const hint = document.getElementById('pg-hint');
    if (!canvas || !panel) return;
    if ((canvas as any).__init) return;
    (canvas as any).__init = true;

    const places: Place[] = JSON.parse(canvas.dataset.places || '[]');
    const wrap = canvas.parentElement!;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.z = 3.2;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(wrap.clientWidth, wrap.clientWidth, false);

    const group = new THREE.Group();
    scene.add(group);

    const isDark = () => document.documentElement.classList.contains('dark');
    const accent = () => (isDark() ? 0x4aa3d9 : 0x0077be);
    const pinCol = () => (isDark() ? 0xffe27a : 0xf0b000);
    const videoPinCol = () => (isDark() ? 0xffa552 : 0xff7a18); // orange for places with a video
    const oceanCol = () => (isDark() ? 0x1a2535 : 0xe8ecf2);
    const borderCol = () => (isDark() ? 0xadb9cc : 0x8a95a8);

    const ocean = new THREE.Mesh(
      new THREE.SphereGeometry(0.995, 64, 48),
      new THREE.MeshBasicMaterial({ color: oceanCol() })
    );
    group.add(ocean);

    // Great-circle distance (degrees) between two lat/lon points.
    function gcDeg(lat1: number, lon1: number, lat2: number, lon2: number) {
      const toRad = Math.PI / 180;
      const a = Math.sin((lat2 - lat1) * toRad / 2) ** 2 +
        Math.cos(lat1 * toRad) * Math.cos(lat2 * toRad) *
        Math.sin((lon2 - lon1) * toRad / 2) ** 2;
      return 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a)) * 180 / Math.PI;
    }
    const CLUSTER_DEG = 1.5; // pins within 1.5° (~165km) of each other count as clustered

    // Three.js layers: main camera sees borders/lakes/ocean (layer 0) + big pins (layer 2).
    // Magnifier camera sees borders/lakes/ocean (layer 0) + a smaller set of pins (layer 1).
    // Layer 0 is default for every object, so we only have to set layers on the pins.
    const LAYER_BIG_PINS = 2;
    const LAYER_SMALL_PINS = 1;
    camera.layers.enable(LAYER_BIG_PINS);
    // Pins — interactive. Orange when the place has a video, yellow otherwise.
    // We create two copies of each pin so the magnifier can use a smaller geometry
    // (the large 3D spheres look correct at globe scale but balloon to fill the
    // viewport when the camera is close, which is what the magnifier does).
    const pins: {
      mesh: THREE.Mesh; halo: THREE.Mesh;
      smallMesh: THREE.Mesh; smallHalo: THREE.Mesh;
      place: Place; hasVideo: boolean;
    }[] = [];
    places.forEach((place) => {
      const pos = latLonToVec3(place.lat, place.lon, 1.015);
      const hasVideo = !!place.video;
      const col = hasVideo ? videoPinCol() : pinCol();
      const haloOpacity = hasVideo ? 0.4 : 0.32;

      // Big pin (main view only)
      const mat = new THREE.MeshBasicMaterial({ color: col });
      const pin = new THREE.Mesh(new THREE.SphereGeometry(0.013, 16, 16), mat);
      pin.position.copy(pos);
      pin.layers.set(LAYER_BIG_PINS);
      (pin as any).userData = { place };
      group.add(pin);

      const halo = new THREE.Mesh(
        new THREE.SphereGeometry(0.028, 16, 16),
        new THREE.MeshBasicMaterial({ color: col, transparent: true, opacity: haloOpacity })
      );
      halo.position.copy(pos);
      halo.layers.set(LAYER_BIG_PINS);
      group.add(halo);

      // Small pin (magnifier view only) — ~1/3 the size so it doesn't dominate the frame
      const smallMat = new THREE.MeshBasicMaterial({ color: col });
      const smallMesh = new THREE.Mesh(new THREE.SphereGeometry(0.0045, 16, 16), smallMat);
      smallMesh.position.copy(pos);
      smallMesh.layers.set(LAYER_SMALL_PINS);
      (smallMesh as any).userData = { place };
      group.add(smallMesh);

      const smallHalo = new THREE.Mesh(
        new THREE.SphereGeometry(0.009, 16, 16),
        new THREE.MeshBasicMaterial({ color: col, transparent: true, opacity: haloOpacity })
      );
      smallHalo.position.copy(pos);
      smallHalo.layers.set(LAYER_SMALL_PINS);
      group.add(smallHalo);

      pins.push({ mesh: pin, halo, smallMesh, smallHalo, place, hasVideo });
    });

    // Precompute clusters: for each place, list all places within CLUSTER_DEG (including self).
    const clusterFor = new Map<string, Place[]>();
    for (const p of pins) {
      const neighbors = pins
        .filter(q => gcDeg(p.place.lat, p.place.lon, q.place.lat, q.place.lon) <= CLUSTER_DEG)
        .map(q => q.place);
      clusterFor.set(p.place.slug, neighbors);
    }

    // Camera + rotation targets
    let targetRotY = 0, targetRotX = 0.3;
    let targetCamZ = 3.2;
    let zoomed = false;
    let selectedPlace: Place | null = null;

    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2();

    function setPointer(e: PointerEvent) {
      const rect = canvas!.getBoundingClientRect();
      pointer.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
      pointer.y = -(((e.clientY - rect.top) / rect.height) * 2 - 1);
    }

    function pinUnderPointer(): typeof pins[number] | null {
      raycaster.layers.set(LAYER_BIG_PINS); // ignore the magnifier-only small pins
      raycaster.setFromCamera(pointer, camera);
      const targets = pins.flatMap(p => [p.mesh, p.halo]);
      const hits = raycaster.intersectObjects(targets, false);
      if (hits.length === 0) return null;
      const hit = hits[0].object;
      return pins.find(p => p.mesh === hit || p.halo === hit) ?? null;
    }

    // Zoom to a place: aim camera at its lat/lon and move closer
    function zoomTo(place: Place) {
      targetRotY = -(place.lon + 90) * Math.PI / 180;
      targetRotX = place.lat * Math.PI / 180;
      targetCamZ = 1.8;
      zoomed = true;
      selectedPlace = place;
      showPanel(place);
      hint && hint.classList.add('opacity-0');
    }
    function zoomOut() {
      targetCamZ = 3.2;
      zoomed = false;
      selectedPlace = null;
      hidePanel();
      hint && hint.classList.remove('opacity-0');
    }

    function showPanel(place: Place) {
      (document.getElementById('pg-title') as HTMLElement).textContent = place.name;
      (document.getElementById('pg-year') as HTMLElement).textContent = place.year || '';
      (document.getElementById('pg-blurb') as HTMLElement).textContent = place.blurb || '';
      const grid = document.getElementById('pg-grid')!;
      const videoMarkup = place.video
        ? `<video class="pg-panel-video" src="/photos/videos/${place.video.file}" controls playsinline preload="metadata" loop></video>`
        : '';
      grid.innerHTML = videoMarkup + place.photos.map(p =>
        `<div class="pg-photo"><img src="/photos/${place.slug}/${p.file}" alt="${p.caption || place.name}" loading="lazy" /></div>`
      ).join('');
      // Two-step show so the opacity/transform transition actually runs
      panel!.style.display = 'block';
      requestAnimationFrame(() => {
        panel!.classList.add('visible');
        panel!.setAttribute('aria-hidden', 'false');
        panel!.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    }

    function hidePanel() {
      panel!.classList.remove('visible');
      panel!.setAttribute('aria-hidden', 'true');
      // Clear content immediately so no text can linger while the panel fades
      const t = document.getElementById('pg-title');
      const y = document.getElementById('pg-year');
      const b = document.getElementById('pg-blurb');
      const g = document.getElementById('pg-grid');
      if (t) t.textContent = '';
      if (y) y.textContent = '';
      if (b) b.textContent = '';
      if (g) g.innerHTML = '';
    }

    // Video hover popup (only for orange pins)
    const vidpop = document.getElementById('pg-vidpop') as HTMLDivElement | null;
    const vidpopVideo = document.getElementById('pg-vidpop-video') as HTMLVideoElement | null;
    const vidpopTitle = document.getElementById('pg-vidpop-title') as HTMLDivElement | null;
    const vidpopDesc = document.getElementById('pg-vidpop-desc') as HTMLDivElement | null;
    let hoveredPlaceSlug: string | null = null;
    // True whenever the cursor is on a pin OR over an open popup — used to pause auto-rotation
    let pointerOnPinOrPopup = false;

    function showVidpop(place: Place, screenX: number, screenY: number) {
      if (!vidpop || !vidpopVideo || !vidpopTitle || !vidpopDesc || !place.video) return;
      if (hoveredPlaceSlug !== place.slug) {
        hoveredPlaceSlug = place.slug;
        vidpopVideo.src = `/photos/videos/${place.video.file}`;
        vidpopTitle.textContent = place.name;
        vidpopDesc.textContent = place.video.description || place.blurb || '';
        vidpopVideo.play().catch(() => {/* autoplay can fail; ignore */});
      }
      // Viewport-fixed positioning. Anchor next to the (screenX, screenY) point,
      // clamped inside the viewport so the popup never gets cut off.
      const popW = vidpop.offsetWidth || 320;
      const popH = vidpop.offsetHeight || 110;
      const margin = 8;
      let left = screenX + 18;
      let top = screenY - popH / 2;
      if (left + popW > window.innerWidth - margin) left = screenX - popW - 18;
      left = Math.max(margin, Math.min(left, window.innerWidth - popW - margin));
      top = Math.max(margin, Math.min(top, window.innerHeight - popH - margin));
      vidpop.style.left = `${left}px`;
      vidpop.style.top = `${top}px`;
      vidpop.classList.add('visible');
      vidpop.setAttribute('aria-hidden', 'false');
    }
    function hideVidpop() {
      if (!vidpop || !vidpopVideo) return;
      hoveredPlaceSlug = null;
      vidpop.classList.remove('visible');
      vidpop.setAttribute('aria-hidden', 'true');
      vidpopVideo.pause();
      vidpopVideo.removeAttribute('src');
      vidpopVideo.load();
    }

    // Cluster magnifier: a small second 3D render of the same scene, zoomed in
    // on the hovered region so overlapping pins separate visually. Click a pin
    // inside the magnifier to zoom to that place.
    const cluster = document.getElementById('pg-cluster') as HTMLDivElement | null;
    const clusterCanvas = document.getElementById('pg-cluster-canvas') as HTMLCanvasElement | null;
    const clusterLabel = document.getElementById('pg-cluster-label') as HTMLDivElement | null;
    let clusterShownForSlug: string | null = null;
    let clusterMembers: Place[] = [];
    let clusterCenterLocal = new THREE.Vector3(); // center of cluster in local (group) coords
    let magRenderer: THREE.WebGLRenderer | null = null;
    let magCamera: THREE.PerspectiveCamera | null = null;
    if (clusterCanvas) {
      magRenderer = new THREE.WebGLRenderer({ canvas: clusterCanvas, alpha: true, antialias: true });
      magRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      magRenderer.setSize(268, 268, false);
      // Narrow FOV ~= telephoto; tight distance ~= satellite-zoomed-in.
      // Together these frame a country-sized region (~3 deg arc).
      magCamera = new THREE.PerspectiveCamera(7, 1, 0.01, 100);
      magCamera.layers.enable(LAYER_SMALL_PINS);
    }

    function showCluster(members: Place[], anchorScreenX: number, anchorScreenY: number, anchorSlug: string) {
      if (!cluster) return;
      clusterShownForSlug = anchorSlug;
      clusterMembers = members;
      // Compute the cluster center in lat/lon (mean of members), convert to local sphere coords
      const centerLat = members.reduce((s, m) => s + m.lat, 0) / members.length;
      const centerLon = members.reduce((s, m) => s + m.lon, 0) / members.length;
      clusterCenterLocal = latLonToVec3(centerLat, centerLon, 1).normalize();
      // Update the label with the hovered place's name
      const hovered = members.find(m => m.slug === anchorSlug);
      if (clusterLabel) clusterLabel.textContent = hovered?.name || '';

      // Viewport-fixed positioning. Place beside the globe wrap when there's room,
      // otherwise above/below it, so the popup never sits on top of the map.
      const wrapRect = wrap.getBoundingClientRect();
      const popW = cluster.offsetWidth || 280;
      const popH = cluster.offsetHeight || 340;
      const margin = 12;
      const rightSpace = window.innerWidth - wrapRect.right - margin;
      const leftSpace = wrapRect.left - margin;
      let left: number, top: number;
      if (rightSpace >= popW) {
        left = wrapRect.right + margin;
        top = wrapRect.top + (wrapRect.height - popH) / 2;
      } else if (leftSpace >= popW) {
        left = wrapRect.left - popW - margin;
        top = wrapRect.top + (wrapRect.height - popH) / 2;
      } else {
        // No side room (mobile): drop the popup below the globe
        left = wrapRect.left + (wrapRect.width - popW) / 2;
        top = wrapRect.bottom + margin;
      }
      // Final clamp inside the viewport
      left = Math.max(margin, Math.min(left, window.innerWidth - popW - margin));
      top = Math.max(margin, Math.min(top, window.innerHeight - popH - margin));
      cluster.style.left = `${left}px`;
      cluster.style.top = `${top}px`;
      cluster.classList.add('visible');
      cluster.setAttribute('aria-hidden', 'false');
    }
    function hideCluster() {
      if (!cluster) return;
      clusterShownForSlug = null;
      clusterMembers = [];
      cluster.classList.remove('visible');
      cluster.setAttribute('aria-hidden', 'true');
    }

    // Pick a pin from a pointer event over the magnifier canvas
    function pinUnderMagPointer(e: PointerEvent): typeof pins[number] | null {
      if (!clusterCanvas || !magCamera) return null;
      const rect = clusterCanvas.getBoundingClientRect();
      const p = new THREE.Vector2(
        ((e.clientX - rect.left) / rect.width) * 2 - 1,
        -(((e.clientY - rect.top) / rect.height) * 2 - 1),
      );
      const rc = new THREE.Raycaster();
      rc.layers.set(LAYER_SMALL_PINS); // only hit-test the small magnifier-only pins
      rc.setFromCamera(p, magCamera);
      const targets = pins.flatMap(pn => [pn.smallMesh, pn.smallHalo]);
      const hits = rc.intersectObjects(targets, false);
      if (hits.length === 0) return null;
      const hit = hits[0].object;
      return pins.find(pn => pn.smallMesh === hit || pn.smallHalo === hit) ?? null;
    }

    clusterCanvas?.addEventListener('pointermove', (e) => {
      const hp = pinUnderMagPointer(e);
      if (clusterCanvas) clusterCanvas.style.cursor = hp ? 'pointer' : 'default';
      if (hp && clusterLabel) clusterLabel.textContent = hp.place.name;
      // If the magnifier-hovered pin has a video, show the preview anchored next to the magnifier
      if (hp && hp.hasVideo && cluster) {
        const cRect = cluster.getBoundingClientRect();
        showVidpop(hp.place, cRect.right, cRect.top + cRect.height / 2);
      } else if (hoveredPlaceSlug !== null) {
        hideVidpop();
      }
    });
    clusterCanvas?.addEventListener('pointerleave', () => {
      // Reset label to the originally hovered place
      const hovered = clusterMembers.find(m => m.slug === clusterShownForSlug);
      if (clusterLabel) clusterLabel.textContent = hovered?.name || '';
      // Don't auto-hide the vidpop if the cursor moved INTO it; its own pointerenter
      // sets pointerOnPinOrPopup and its pointerleave will hide it.
    });
    clusterCanvas?.addEventListener('click', (e) => {
      const hp = pinUnderMagPointer(e);
      if (hp) {
        hideCluster();
        hideVidpop();
        zoomTo(hp.place);
      }
    });
    // Keep popups alive while the cursor is over them
    cluster?.addEventListener('pointerenter', () => { pointerOnPinOrPopup = true; });
    cluster?.addEventListener('pointerleave', () => {
      pointerOnPinOrPopup = false;
      hideCluster();
    });
    vidpop?.addEventListener('pointerenter', () => { pointerOnPinOrPopup = true; });
    vidpop?.addEventListener('pointerleave', () => {
      pointerOnPinOrPopup = false;
      hideVidpop();
    });
    // Close buttons (especially helpful on touch where "tap outside" is non-obvious)
    document.getElementById('pg-vidpop-close')?.addEventListener('click', (e) => {
      e.stopPropagation();
      hideVidpop();
    });
    document.getElementById('pg-cluster-close')?.addEventListener('click', (e) => {
      e.stopPropagation();
      hideCluster();
      hideVidpop();
    });

    // Interaction
    let dragging = false;
    let dragMoved = false;
    let lastX = 0, lastY = 0;

    canvas.addEventListener('pointerdown', (e) => {
      setPointer(e);
      dragging = true;
      dragMoved = false;
      lastX = e.clientX;
      lastY = e.clientY;
      canvas.setPointerCapture(e.pointerId);
      canvas.classList.add('grabbing');
    });

    // Devices that don't support hover (touch primarily) get tap-to-preview;
    // devices with hover get hover-to-preview.
    const hoverSupported = window.matchMedia('(hover: hover)').matches;

    canvas.addEventListener('pointermove', (e) => {
      setPointer(e);
      if (dragging) {
        const dx = e.clientX - lastX;
        const dy = e.clientY - lastY;
        if (Math.abs(dx) + Math.abs(dy) > 3) dragMoved = true;
        const factor = zoomed ? 0.003 : 0.006;
        targetRotY += dx * factor;
        targetRotX += dy * factor;
        targetRotX = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, targetRotX));
        lastX = e.clientX; lastY = e.clientY;
      } else {
        const hp = pinUnderPointer();
        canvas.style.cursor = hp ? 'pointer' : '';
        pointerOnPinOrPopup = !!hp;
        if (hoverSupported) {
          if (hp) {
            const members = clusterFor.get(hp.place.slug) || [hp.place];
            if (members.length > 1) {
              showCluster(members, e.clientX, e.clientY, hp.place.slug);
            } else if (clusterShownForSlug !== null) {
              hideCluster();
            }
            if (hp.hasVideo) {
              showVidpop(hp.place, e.clientX, e.clientY);
            } else if (hoveredPlaceSlug !== null) {
              hideVidpop();
            }
          } else {
            if (hoveredPlaceSlug !== null) hideVidpop();
            // Don't auto-hide the cluster popup on pointer leaving the pin — the
            // popup's own pointerleave handler will hide it when the cursor leaves it too.
          }
        }
      }
    });

    canvas.addEventListener('pointerup', (e) => {
      dragging = false;
      canvas.releasePointerCapture?.(e.pointerId);
      canvas.classList.remove('grabbing');
      if (!dragMoved) {
        setPointer(e);
        const hp = pinUnderPointer();
        if (hp) {
          const members = clusterFor.get(hp.place.slug) || [hp.place];
          const inCluster = members.length > 1;
          // Touch path: first tap on a video pin previews; tapping again zooms in.
          // For clusters, first tap shows the list; second tap zooms.
          if (!hoverSupported && hp.hasVideo && hoveredPlaceSlug !== hp.place.slug) {
            showVidpop(hp.place, e.clientX, e.clientY);
            if (inCluster) showCluster(members, e.clientX, e.clientY, hp.place.slug);
          } else if (!hoverSupported && inCluster && clusterShownForSlug !== hp.place.slug) {
            showCluster(members, e.clientX, e.clientY, hp.place.slug);
          } else {
            hideVidpop();
            hideCluster();
            zoomTo(hp.place);
          }
        } else if (!hoverSupported) {
          // Tap outside a pin dismisses open previews
          hideVidpop();
          hideCluster();
        }
      }
    });

    canvas.addEventListener('pointerleave', () => {
      canvas.style.cursor = '';
      pointerOnPinOrPopup = false;
      if (hoverSupported) {
        hideVidpop();
        // Note: cluster popup stays open if user is hovering it; its own pointerleave hides it.
      }
    });

    document.getElementById('pg-close')?.addEventListener('click', zoomOut);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && zoomed) zoomOut();
    });

    const ro = new ResizeObserver(() => {
      const d = wrap.clientWidth;
      renderer.setSize(d, d, false);
      camera.aspect = 1;
      camera.updateProjectionMatrix();
    });
    ro.observe(wrap);

    // Animation loop
    let raf = 0;
    let t = 0;
    function loop() {
      t += 0.016;
      // Auto-rotate unless dragging, zoomed in, or hovering a pin / popup
      if (!dragging && !zoomed && !pointerOnPinOrPopup) targetRotY += 0.002;
      group.rotation.y += (targetRotY - group.rotation.y) * 0.08;
      group.rotation.x += (targetRotX - group.rotation.x) * 0.08;
      camera.position.z += (targetCamZ - camera.position.z) * 0.08;

      // Pulse halos so pins draw the eye (both the big and the magnifier-only small ones)
      pins.forEach((p, i) => {
        const s = 1 + Math.sin(t * 2 + i) * 0.15;
        p.halo.scale.setScalar(s);
        p.smallHalo.scale.setScalar(s);
      });

      renderer.render(scene, camera);

      // Magnifier render: same scene, camera aimed at the hovered cluster from closer in
      if (magRenderer && magCamera && clusterShownForSlug) {
        // World position of the cluster center (after current group rotation)
        const worldCenter = clusterCenterLocal.clone().applyMatrix4(group.matrixWorld);
        // Camera sits 1.3 units from origin in the cluster's direction (just above the
        // sphere surface) and looks at the cluster center itself so it stays framed.
        magCamera.position.copy(worldCenter).normalize().multiplyScalar(1.3);
        magCamera.lookAt(worldCenter);
        magRenderer.render(scene, magCamera);
      }

      raf = requestAnimationFrame(loop);
    }
    loop();

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(raf);
      ro.disconnect();
      renderer.dispose();
    }, { once: true });

    // Country outlines (decorative, non-interactive)
    try {
      const res = await fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json');
      const topo = await res.json();
      const countries: any = feature(topo, topo.objects.countries);

      const borderMat = new THREE.LineBasicMaterial({ color: borderCol(), transparent: true, opacity: 0.95 });
      const accentLineMat = new THREE.LineBasicMaterial({ color: accent(), transparent: true, opacity: 0.9 });
      // All country borders, including coastlines (no filter → keep a === b exterior arcs)
      const borderLs = mesh(topo, topo.objects.countries);
      group.add(meshToLineSegments(borderLs, 1.001, borderMat));

      // Visited countries: single accent outline on top of the base borders
      for (const f of countries.features) {
        const id = String(f.id).padStart(3, '0');
        if (!VISITED_IDS.has(id)) continue;
        const polys = f.geometry.type === 'Polygon' ? [f.geometry.coordinates] : f.geometry.coordinates;
        for (const poly of polys) {
          group.add(ringToLine(poly[0], 1.006, accentLineMat));
        }
      }

      const mo = new MutationObserver(() => {
        (ocean.material as THREE.MeshBasicMaterial).color.setHex(oceanCol());
        borderMat.color.setHex(borderCol());
        accentLineMat.color.setHex(accent());
        pins.forEach(p => {
          const c = p.hasVideo ? videoPinCol() : pinCol();
          ((p.mesh.material as THREE.MeshBasicMaterial)).color.setHex(c);
          ((p.halo.material as THREE.MeshBasicMaterial)).color.setHex(c);
          ((p.smallMesh.material as THREE.MeshBasicMaterial)).color.setHex(c);
          ((p.smallHalo.material as THREE.MeshBasicMaterial)).color.setHex(c);
        });
      });
      mo.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      document.addEventListener('astro:before-swap', () => mo.disconnect(), { once: true });

      // Major lakes (Natural Earth 110m → only the big ones: Great Lakes, Caspian, Victoria, etc.)
      // Fill the lake interior in ocean color so country borders that cut through the
      // lake (because the lake is split between countries) are masked, then re-stroke
      // the outline so the lake reads as water.
      try {
        const lakesRes = await fetch('https://cdn.jsdelivr.net/gh/nvkelso/natural-earth-vector@master/geojson/ne_110m_lakes.geojson');
        const lakesGeo = await lakesRes.json();
        const lakeFillMat = new THREE.MeshBasicMaterial({ color: 0x000000, side: THREE.DoubleSide });
        for (const f of lakesGeo.features) {
          const polys = f.geometry.type === 'Polygon' ? [f.geometry.coordinates] : f.geometry.coordinates;
          for (const poly of polys) {
            const outer = poly[0];
            const holes = poly.slice(1);
            try {
              group.add(ringFillMesh(outer, holes, 1.007, lakeFillMat));
            } catch {
              /* skip un-triangulable polygons */
            }
            group.add(ringToLine(outer, 1.0075, borderMat));
          }
        }
      } catch (err) {
        console.warn('PhotoGlobe: lake shapes failed to load.', err);
      }
    } catch (err) {
      console.warn('PhotoGlobe: country shapes failed to load.', err);
    }
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
