---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';

const awards = [
  "2021 National Champion in Quiz Bowl · PACE National Quiz Bowl Championship, 1st Place (Captain, TJHSST Quizbowl)",
  "2022 High School National Championship Tournament ~ 5th Place",
  "2021 Virginia History Bee Champion",
  "2022 VHSL Scholastic Bowl State Champions",
  "In 2021, I was on a game show with some teammates from TJ — you might find it on YouTube.",
  "2021 National History Bowl Runner-Up Team (President, TJHSST History Bowl)",
  "National Merit Scholarship (Sponsored by Leidos, Inc.)",
  "National Federal Reserve Challenge Team (1st Place), Presenter and Labor Specialist",
  "Health Scholar (Awarded by Princeton Center for Health and Wellbeing)",
];
---

<BaseLayout title="Hobbies | Elliot S. Lee">
  <section class="max-w-4xl mx-auto px-6 pt-12 pb-20">
    <div class="text-center mb-8">
      <h1 class="font-serif font-bold text-4xl md:text-5xl mb-3">Hobbies & Interests</h1>
      <p class="font-serif opacity-80 text-lg max-w-2xl mx-auto">
        I'm not the heavy-hitting quizbowler I was in high school, but I've moved on to more interesting things. I like exploring new places, geeking over history and geography, and taking over the world (in Civ VI).
      </p>
    </div>

    <ScrollReveal>
      <div class="card p-8 mb-8">
        <h2 class="font-serif font-bold text-2xl mb-4">Awards</h2>
        <ul class="list-disc pl-6 space-y-2 font-serif">
          {awards.map(a => <li>{a}</li>)}
        </ul>
      </div>
    </ScrollReveal>

    <ScrollReveal>
      <div class="card p-8">
        <h2 class="font-serif font-bold text-2xl mb-4">Miscellaneous</h2>
        <ul class="space-y-2 font-serif text-[1.05rem]">
          <li>🐧 Keep the African Penguin from a 2035 extinction by supporting <a href="https://sanccob.co.za" target="_blank" rel="noopener">SANCCOB</a></li>
          <li>🎹 Piano [favorite composer: Tchaikovsky]</li>
          <li>🎶 Clarinet [favorite classical piece: Prince Igor Overture · favorite band piece: El Camino Real]</li>
          <li>🚴 Cycling enthusiast</li>
          <li>🪐 Fan of <a href="https://www.coldplay.com/" target="_blank" rel="noopener">Coldplay</a>, <a href="https://www.wearethestrike.com/" target="_blank" rel="noopener">The Strike</a>, and <a href="https://www.brucehornsby.com/" target="_blank" rel="noopener">Bruce Hornsby &amp; The Range</a>.</li>
        </ul>
      </div>
    </ScrollReveal>
  </section>
</BaseLayout>
