---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Blog | Elliot S. Lee">
  <section class="max-w-3xl mx-auto px-6 pt-12 pb-20">
    <div class="text-center mb-10">
      <h1 class="font-serif font-bold text-4xl md:text-5xl mb-3">Blog</h1>
    </div>

    {posts.length === 0 && (
      <p class="text-center opacity-60 italic">No posts yet — come back soon.</p>
    )}

    <ul class="space-y-4 list-none p-0">
      {posts.map((p, i) => (
        <ScrollReveal delay={i * 80}>
          <li>
            <a href={`/blog/${p.slug}`} class="block card p-6 no-underline hover:!-translate-y-1 transition">
              <div class="flex items-baseline justify-between gap-4 mb-2">
                <h2 class="font-serif font-bold text-xl">{p.data.title}</h2>
                <time class="text-xs font-sans opacity-60 shrink-0">
                  {p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <p class="font-serif opacity-80">{p.data.description}</p>
              {p.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {p.data.tags.map(t => <span class="tag" style="cursor:default">{t}</span>)}
                </div>
              )}
            </a>
          </li>
        </ScrollReveal>
      ))}
    </ul>
  </section>
</BaseLayout>
