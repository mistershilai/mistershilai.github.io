---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Globe from '@/components/Globe.astro';
import TypingText from '@/components/TypingText.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
---

<BaseLayout title="Elliot S. Lee | Home">
  <!-- Graduation popup: shows on first home-page visit, dismiss persists in localStorage -->
  <div id="grad-popup" class="grad-popup-backdrop" aria-hidden="true">
    <div class="grad-popup" role="dialog" aria-labelledby="grad-popup-title" aria-modal="true">
      <button id="grad-popup-close" class="grad-popup-close" aria-label="Close announcement">×</button>
      <div class="grad-popup-photos">
        <img class="grad-popup-photo is-active" src="/photos/graduation/IMG_3015.jpeg" alt="" loading="eager" />
        <img class="grad-popup-photo" src="/photos/graduation/IMG_3691.jpeg" alt="" loading="lazy" />
        <img class="grad-popup-photo" src="/photos/graduation/IMG_3705.jpeg" alt="" loading="lazy" />
        <img class="grad-popup-photo" src="/photos/graduation/IMG_7305.jpeg" alt="" loading="lazy" />
        <div class="grad-popup-photo-overlay" aria-hidden="true"></div>
        <div class="grad-popup-eyebrow grad-popup-eyebrow-overlay">
          <span class="grad-popup-shield" aria-hidden="true">🐅</span>
          <span>Princeton, Class of 2026</span>
        </div>
      </div>
      <div class="grad-popup-content">
        <h2 id="grad-popup-title" class="grad-popup-title">I just graduated.</h2>
        <p class="grad-popup-body">
          The work I'm proudest of isn't really mine. It came from advisors who gave me their time, friends who carried me through the hardest weeks, collaborators in Botswana who let me work on something that mattered, and a first squad that taught me what showing up looks like.
        </p>
        <p class="grad-popup-body">
          Four years of being shaped by people more generous than I had any right to expect. Thank you, all of you.
        </p>
        <p class="grad-popup-signature">Elliot, ORFE '26</p>
      </div>
    </div>
  </div>

  <section class="max-w-5xl mx-auto px-6 pt-10 md:pt-16 pb-20">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <div class="flex items-center gap-4 mb-3">
          <p class="text-sm font-sans uppercase tracking-[0.2em] opacity-60">hello, world</p>
          <span class="opacity-30">·</span>
          <div class="flex items-center gap-3">
            <a
              href="https://www.linkedin.com/in/elliot-lee-072007249/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="opacity-60 hover:opacity-100 transition-opacity no-underline"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
            </a>
            <a
              href="mailto:mistershilai@gmail.com"
              aria-label="Email"
              class="opacity-60 hover:opacity-100 transition-opacity no-underline"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="M2 6l10 7 10-7"/>
              </svg>
            </a>
            <a
              href="https://www.instagram.com/elliot.s.lee/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              class="opacity-60 hover:opacity-100 transition-opacity no-underline"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          </div>
        </div>
        <TypingText phrases={[
          "Elliot S. Lee",
          "Princeton ORFE '26",
          "Predoctoral Fellow @ Berkeley Haas",
          "Global Health × Applied Math",
          "Aspiring Surgeon-Statistician",
          "ML/AI4H Enthusiast",
        ]} />
        <p class="mt-5 text-lg leading-relaxed font-serif opacity-90">
          A 2026 Princeton ORFE graduate and predoctoral fellow at Berkeley Haas, with interests in health systems, biostatistics, and building things that matter.
        </p>
        <div class="mt-7 flex flex-wrap gap-3 font-sans text-sm">
          <a href="/about" class="px-4 py-2 rounded-full bg-[color:var(--color-accent)] text-white no-underline hover:opacity-90">about me →</a>
          <a href="/projects" class="px-4 py-2 rounded-full border border-current no-underline hover:bg-black/5 dark:hover:bg-white/10">projects</a>
          <a href="/contact" class="px-4 py-2 rounded-full border border-current no-underline hover:bg-black/5 dark:hover:bg-white/10">get in touch</a>
        </div>
      </div>
      <div class="order-first md:order-last">
        <Globe />
        <p class="text-center text-xs font-sans opacity-50 mt-3">↻ drag to rotate · dots are places I've visited</p>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 pb-24">
    <ScrollReveal>
      <div class="card p-8">
        <h2 class="font-serif text-2xl font-bold mb-6">Currently</h2>
        <div class="grid md:grid-cols-3 gap-6 font-sans text-sm">
          <div>
            <div class="text-[color:var(--color-accent)] font-semibold mb-1">Research</div>
            <p class="opacity-80">Designing antimicrobial supply chains in Botswana with Princeton ORFE × ACHAP.</p>
          </div>
          <div>
            <div class="text-[color:var(--color-accent)] font-semibold mb-1">Modeling</div>
            <p class="opacity-80">Genetic mutation effects in population genomics at Lewis-Sigler.</p>
          </div>
          <div>
            <div class="text-[color:var(--color-accent)] font-semibold mb-1">Service</div>
            <p class="opacity-80">EMT and disaster-response volunteer.</p>
          </div>
        </div>
      </div>
    </ScrollReveal>
  </section>
</BaseLayout>

<style>
  .grad-popup-backdrop {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .grad-popup-backdrop.visible {
    opacity: 1;
    pointer-events: auto;
  }
  .grad-popup {
    position: relative;
    width: 100%;
    max-width: 560px;
    background: #0c0c0c;
    color: #f8f4ec;
    border: 1px solid rgba(245, 128, 37, 0.4);
    border-top: 4px solid #f58025; /* Princeton orange */
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(245, 128, 37, 0.1);
    transform: translateY(14px) scale(0.98);
    transition: transform 0.4s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .grad-popup-backdrop.visible .grad-popup {
    transform: translateY(0) scale(1);
  }
  .grad-popup-close {
    position: absolute;
    top: 0.75rem;
    right: 0.9rem;
    z-index: 3;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    line-height: 1;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #f8f4ec;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.2s, border-color 0.2s;
  }
  .grad-popup-close:hover {
    background: rgba(245, 128, 37, 0.6);
    border-color: rgba(245, 128, 37, 0.8);
  }
  /* Crossfading Ken-Burns photo strip across the top of the popup */
  .grad-popup-photos {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #000;
  }
  .grad-popup-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1.08);
    transition: opacity 1.2s ease;
  }
  .grad-popup-photo.is-active {
    opacity: 1;
    animation: gradKenBurns 6s ease-out forwards;
  }
  @keyframes gradKenBurns {
    from { transform: scale(1.12); }
    to   { transform: scale(1.0);  }
  }
  .grad-popup-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0) 35%, rgba(0,0,0,0) 55%, rgba(0,0,0,0.7) 100%);
    pointer-events: none;
  }
  .grad-popup-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #f58025;
  }
  .grad-popup-eyebrow-overlay {
    position: absolute;
    left: 1.25rem;
    bottom: 1rem;
    z-index: 2;
    color: #ffd9b3;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }
  .grad-popup-shield {
    font-size: 1.1rem;
    line-height: 1;
  }
  .grad-popup-content {
    padding: 1.5rem 1.75rem 1.5rem;
  }
  .grad-popup-title {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.85rem;
    line-height: 1.1;
    margin: 0 0 1rem;
    color: #ffffff;
  }
  .grad-popup-body {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.55;
    margin: 0 0 0.85rem;
    color: rgba(248, 244, 236, 0.92);
  }
  .grad-popup-signature {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    margin: 1.2rem 0 0;
    color: #f58025;
  }
  @media (max-width: 480px) {
    .grad-popup-content { padding: 1.25rem 1.25rem 1.2rem; }
    .grad-popup-title { font-size: 1.5rem; }
    .grad-popup-body { font-size: 0.95rem; }
    .grad-popup-eyebrow-overlay { left: 1rem; bottom: 0.8rem; }
  }
</style>

<script>
  // Show the graduation popup on first visit; remember dismissal in localStorage.
  function initGradPopup() {
    const popup = document.getElementById('grad-popup');
    const closeBtn = document.getElementById('grad-popup-close');
    if (!popup || !closeBtn) return;
    if ((popup as any).__init) return;
    (popup as any).__init = true;

    const DISMISS_KEY = 'grad-popup-2026-dismissed';
    if (localStorage.getItem(DISMISS_KEY)) return;

    function show() {
      popup!.classList.add('visible');
      popup!.setAttribute('aria-hidden', 'false');
    }
    function hide() {
      popup!.classList.remove('visible');
      popup!.setAttribute('aria-hidden', 'true');
      try { localStorage.setItem(DISMISS_KEY, '1'); } catch {}
      if (cycleTimer) {
        clearInterval(cycleTimer);
        cycleTimer = null;
      }
    }

    // Photo crossfade — restart Ken Burns animation on each transition
    const photos = Array.from(popup.querySelectorAll('.grad-popup-photo')) as HTMLElement[];
    let cycleIdx = 0;
    let cycleTimer: ReturnType<typeof setInterval> | null = null;
    if (photos.length > 1) {
      cycleTimer = setInterval(() => {
        photos[cycleIdx].classList.remove('is-active');
        cycleIdx = (cycleIdx + 1) % photos.length;
        // Force animation restart by removing/reapplying the class on next frame
        const next = photos[cycleIdx];
        next.classList.remove('is-active');
        void next.offsetWidth;
        next.classList.add('is-active');
      }, 4200);
    }

    // Small delay so the page can render first
    setTimeout(show, 900);

    closeBtn.addEventListener('click', hide);
    // Click on the backdrop (outside the modal) also dismisses
    popup.addEventListener('click', (e) => {
      if (e.target === popup) hide();
    });
    // Escape key dismisses too
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && popup.classList.contains('visible')) hide();
    });
  }

  initGradPopup();
  document.addEventListener('astro:page-load', initGradPopup);
</script>
