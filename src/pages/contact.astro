---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
---

<BaseLayout title="Contact | Elliot S. Lee">
  <section class="max-w-2xl mx-auto px-6 pt-12 pb-20">
    <div class="text-center mb-8">
      <img src="/IMG_4086.jpg" alt="Elliot S. Lee" class="w-32 h-32 rounded-full object-cover border-4 border-[color:var(--color-accent)] mb-5 mx-auto" />
      <h1 class="font-serif font-bold text-4xl mb-3">Contact Me</h1>
      <p class="font-serif opacity-80">I'm always happy to connect! For research, collaboration, or just to say hello.</p>
    </div>

    <ScrollReveal>
      <div class="card p-8">
        <p class="mb-6 font-serif">
          <strong>Email:</strong> <a href="mailto:mistershilai@gmail.com">mistershilai@gmail.com</a>
        </p>

        <form id="contact-form" class="space-y-4 font-sans text-sm">
          <div>
            <label for="name" class="block mb-1 font-semibold">Name</label>
            <input
              id="name" name="name" required
              class="w-full px-3 py-2 rounded-md border border-black/15 dark:border-white/15 bg-transparent focus:outline-none focus:border-[color:var(--color-accent)]"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block mb-1 font-semibold">Email</label>
            <input
              id="email" name="email" type="email" required
              class="w-full px-3 py-2 rounded-md border border-black/15 dark:border-white/15 bg-transparent focus:outline-none focus:border-[color:var(--color-accent)]"
              placeholder="your@email.com"
            />
          </div>
          <div>
            <label for="message" class="block mb-1 font-semibold">Message</label>
            <textarea
              id="message" name="message" rows="5" required
              class="w-full px-3 py-2 rounded-md border border-black/15 dark:border-white/15 bg-transparent focus:outline-none focus:border-[color:var(--color-accent)]"
              placeholder="Type your message here"
            ></textarea>
          </div>
          <!-- Honeypot (bots fill this) -->
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" />

          <button
            type="submit"
            class="px-5 py-2.5 rounded-full bg-[color:var(--color-accent)] text-white font-semibold hover:opacity-90 transition disabled:opacity-50"
          >
            Send
          </button>

          <p id="form-status" class="text-sm mt-3" aria-live="polite"></p>
        </form>
      </div>
    </ScrollReveal>
  </section>
</BaseLayout>

<script>
  function wire() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form || (form as any).__wired) return;
    (form as any).__wired = true;
    const status = document.getElementById('form-status')!;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';
      btn.disabled = true;
      btn.textContent = 'Sending…';

      try {
        const data = Object.fromEntries(new FormData(form).entries());
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(body.error || 'Something went wrong.');
        status.textContent = '✓ Sent! I\u2019ll get back to you soon.';
        status.className = 'text-sm mt-3 text-green-600 dark:text-green-400';
        form.reset();
      } catch (err: any) {
        status.textContent = `✗ ${err.message || 'Failed to send. Try emailing me directly.'}`;
        status.className = 'text-sm mt-3 text-red-600 dark:text-red-400';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Send';
      }
    });
  }
  wire();
  document.addEventListener('astro:page-load', wire);
</script>
